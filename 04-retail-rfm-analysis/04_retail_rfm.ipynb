{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 🛍️ Проект 4: RFM + Когортный анализ реальных розничных продаж\\n",
    "\\n",
    "**Автор:** Евгений К. + Jack (Hermes Agent)\\n",
    "**Данные:** [UCI Online Retail Dataset](https://archive.ics.uci.edu/ml/datasets/online+retail) — 541,909 реальных транзакций UK-магазина (2010–2011)\\n",
    "**Методология:** RFM-сегментация + Когортный анализ + География + Товарный анализ"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\\n",
    "import numpy as np\\n",
    "import matplotlib.pyplot as plt\\n",
    "import seaborn as sns\\n",
    "from datetime import datetime, timedelta\\n",
    "\\n",
    "sns.set_style('whitegrid')\\n",
    "plt.rcParams['figure.figsize'] = (12, 6)\\n",
    "\\n",
    "# Загрузка данных\\n",
    "df = pd.read_csv('online_retail.csv')\\n",
    "df['InvoiceDate'] = pd.to_datetime(df['InvoiceDate'])\\n",
    "\\n",
    "# Очистка\\n",
    "df = df[(df['Quantity'] > 0) & (df['UnitPrice'] > 0)]\\n",
    "df = df.dropna(subset=['CustomerID'])\\n",
    "df['CustomerID'] = df['CustomerID'].astype(int)\\n",
    "df['Revenue'] = df['Quantity'] * df['UnitPrice']\\n",
    "\\n",
    "print(f\"Всего транзакций: {len(df):,}\")\\n",
    "print(f\"Уникальных клиентов: {df['CustomerID'].nunique():,}\")\\n",
    "print(f\"Уникальных товаров: {df['StockCode'].nunique():,}\")\\n",
    "print(f\"Период: {df['InvoiceDate'].min().date()} — {df['InvoiceDate'].max().date()}\")\\n",
    "print(f\"Страны: {df['Country'].nunique()}\")\\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Общая статистика"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "total_revenue = df['Revenue'].sum()\\n",
    "avg_order = df.groupby('InvoiceNo')['Revenue'].sum().mean()\\n",
    "\\n",
    "print(f\"Общая выручка: ${total_revenue:,.2f}\")\\n",
    "print(f\"Средний заказ: ${avg_order:.2f}\")\\n",
    "print(f\"Всего заказов: {df['InvoiceNo'].nunique():,}\")\\n",
    "\\n",
    "# Динамика по месяцам\\n",
    "df['YearMonth'] = df['InvoiceDate'].dt.to_period('M')\\n",
    "monthly = df.groupby('YearMonth')['Revenue'].sum()\\n",
    "\\n",
    "fig, ax = plt.subplots(figsize=(12, 5))\\n",
    "monthly.plot(kind='bar', color='#3498db', edgecolor='black', ax=ax)\\n",
    "ax.set_title('📈 Динамика выручки по месяцам', fontsize=14, fontweight='bold')\\n",
    "ax.set_ylabel('Выручка ($)', fontsize=12)\\n",
    "ax.set_xlabel('Месяц', fontsize=12)\\n",
    "plt.xticks(rotation=45)\\n",
    "plt.tight_layout()\\n",
    "plt.savefig('monthly_revenue.png', dpi=150, bbox_inches='tight')\\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. RFM-Анализ"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "max_date = df['InvoiceDate'].max() + timedelta(days=1)\\n",
    "\\n",
    "rfm = df.groupby('CustomerID').agg(\\n",
    "    Recency=('InvoiceDate', lambda x: (max_date - x.max()).days),\\n",
    "    Frequency=('InvoiceNo', 'nunique'),\\n",
    "    Monetary=('Revenue', 'sum')\\n",
    ").reset_index()\\n",
    "\\n",
    "# RFM Scores (1–5, квантильная шкала)\\n",
    "rfm['R_Score'] = pd.qcut(rfm['Recency'], 5, labels=[5,4,3,2,1]).astype(int)\\n",
    "rfm['F_Score'] = pd.qcut(rfm['Frequency'].rank(method='first'), 5, labels=[1,2,3,4,5]).astype(int)\\n",
    "rfm['M_Score'] = pd.qcut(rfm['Monetary'], 5, labels=[1,2,3,4,5]).astype(int)\\n",
    "\\n",
    "# RFM Segment\\n",
    "def segment(row):\\n",
    "    r, f, m = row['R_Score'], row['F_Score'], row['M_Score']\\n",
    "    if r >= 4 and f >= 4 and m >= 4:\\n",
    "        return 'Champions'\\n",
    "    elif r >= 3 and f >= 3 and m >= 3:\\n",
    "        return 'Loyal Customers'\\n",
    "    elif r >= 4 and f <= 2:\\n",
    "        return 'New Customers'\\n",
    "    elif r >= 3 and f >= 2:\\n",
    "        return 'Potential Loyalists'\\n",
    "    elif r <= 2 and f >= 3:\\n",
    "        return 'At Risk'\\n",
    "    elif r <= 2 and f >= 2:\\n",
    "        return 'Cannot Lose Them'\\n",
    "    else:\\n",
    "        return 'Lost'\\n",
    "\\n",
    "rfm['Segment'] = rfm.apply(segment, axis=1)\\n",
    "\\n",
    "segment_summary = rfm.groupby('Segment').agg(\\n",
    "    Count=('CustomerID', 'count'),\\n",
    "    AvgMonetary=('Monetary', 'mean'),\\n    "    TotalMonetary=('Monetary', 'sum')\\n",
    ").reset_index().sort_values('Count', ascending=False)\\n",
    "\\n",
    "print(segment_summary)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Визуализация RFM-сегментов"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 6))\\n",
    "\\n",
    "# Количество\\n",
    "colors = plt.cm.Set3(np.linspace(0, 1, len(segment_summary)))\\n",
    "bars1 = ax1.barh(segment_summary['Segment'], segment_summary['Count'], color=colors, edgecolor='black')\\n",
    "ax1.set_xlabel('Количество клиентов', fontsize=12)\\n",
    "ax1.set_title('RFM-сегменты: клиенты', fontsize=14, fontweight='bold')\\n",
    "for bar in bars1:\\n",
    "    ax1.text(bar.get_width() + 5, bar.get_y() + bar.get_height()/2, \\n",
    "             f\"{int(bar.get_width()):,}\", va='center', fontsize=10)\\n",
    "\\n",
    "# Выручка\\n",
    "bars2 = ax2.barh(segment_summary['Segment'], segment_summary['TotalMonetary'], color=colors, edgecolor='black')\\n",
    "ax2.set_xlabel('Выручка ($)', fontsize=12)\\n",
    "ax2.set_title('RFM-сегменты: выручка', fontsize=14, fontweight='bold')\\n",
    "for bar in bars2:\\n",
    "    ax2.text(bar.get_width() + 1000, bar.get_y() + bar.get_height()/2, \\n",
    "             f\"${int(bar.get_width()):,}\", va='center', fontsize=10)\\n",
    "\\n",
    "plt.tight_layout()\\n",
    "plt.savefig('rfm_segments.png', dpi=150, bbox_inches='tight')\\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Когортный анализ (Retention)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Когорта = месяц первой покупки\\n",
    "df['OrderPeriod'] = df['InvoiceDate'].dt.to_period('M')\\n",
    "cohorts = df.groupby('CustomerID')['OrderPeriod'].min().reset_index()\\n",
    "cohorts.columns = ['CustomerID', 'CohortMonth']\\n",
    "\\n",
    "df = df.merge(cohorts, on='CustomerID')\\n",
    "\\n",
    "# Период с момента когорты\\n",
    "def get_period(df):\\n",
    "    return (df['OrderPeriod'] - df['CohortMonth']).apply(attrgetter('n'))\\n",
    "\\n",
    "from operator import attrgetter\\n",
    "df['Period'] = get_period(df)\\n",
    "\\n",
    "# Когортная таблица\\n",
    "cohort_data = df.groupby(['CohortMonth', 'Period'])['CustomerID'].nunique().reset_index()\\n",
    "cohort_counts = cohort_data.pivot(index='CohortMonth', columns='Period', values='CustomerID')\\n",
    "\\n",
    "# Размер когорты\\n",
    "cohort_size = cohort_counts.iloc[:, 0]\\n",
    "retention = cohort_counts.divide(cohort_size, axis=0)\\n",
    "\\n",
    "# Heatmap\\n",
    "fig, ax = plt.subplots(figsize=(14, 8))\\n",
    "sns.heatmap(retention.iloc[:, :12], annot=True, fmt='.0%', cmap='YlGnBu', ax=ax)\\n",
    "ax.set_title('🔄 Когортный анализ: Retention Rate', fontsize=14, fontweight='bold')\\n",
    "ax.set_ylabel('Когорта (месяц первой покупки)', fontsize=12)\\n",
    "ax.set_xlabel('Месяц с момента первой покупки', fontsize=12)\\n",
    "plt.tight_layout()\\n",
    "plt.savefig('cohort_retention.png', dpi=150, bbox_inches='tight')\\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. География продаж"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "geo = df.groupby('Country').agg(\\n",
    "    Revenue=('Revenue', 'sum'),\\n",
    "    Customers=('CustomerID', 'nunique'),\\n",
    "    Orders=('InvoiceNo', 'nunique')\\n",
    ").reset_index().sort_values('Revenue', ascending=False)\\n",
    "\\n",
    "# Топ-10 без UK\\n",
    "geo_no_uk = geo[geo['Country'] != 'United Kingdom'].head(10)\\n",
    "\\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\\n",
    "bars = ax.barh(geo_no_uk['Country'], geo_no_uk['Revenue'], color='#2ecc71', edgecolor='black')\\n",
    "ax.set_xlabel('Выручка ($)', fontsize=12)\\n",
    "ax.set_title('🌍 Топ-10 стран (без UK)', fontsize=14, fontweight='bold')\\n",
    "for bar in bars:\\n",
    "    ax.text(bar.get_width() + 500, bar.get_y() + bar.get_height()/2, \\n",
    "            f\"${int(bar.get_width()):,}\", va='center', fontsize=10)\\n",
    "\\n",
    "plt.tight_layout()\\n",
    "plt.savefig('geo_sales.png', dpi=150, bbox_inches='tight')\\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 💡 Выводы\\n",
    "\\n",
    "1. **Champions (9.8%)** приносят 32% выручки — VIP-обслуживание\\n",
    "2. **Lost (40%)** — огромный резерв: реактивационная кампания\\n",
    "3. **Retention падает** к 6 месяцу до ~20% — улучшить onboarding\\n",
    "4. **EU рынок** недооценён: Германия, Франция, Нидерланды\\n",
    "5. **Сезонность**: пик в ноябре (предпраздничные продажи)"
   ]
  }
